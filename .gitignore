.DS_Store
*.pyc
*.egg-info
*.swp
tags
node_modules
__pycache__
.venv/
.superpowers/
docs/

# Playwright MCP server's per-run snapshot / console-log dumps. Created
# under repo root when QA runs drive the desk via the MCP browser tools.
# (The Playwright e2e tier was removed from the project — see commit
# history. This entry stays because the MCP server is a separate dev
# tool that still writes scratch here.)
.playwright-mcp/

# Local Claude Code settings (per-developer)
.claude/

# Per-developer Claude project state / plans / memory under ~/.claude
# never live in the repo, but the agent occasionally writes scratch
# under these paths during local audits — ignore them defensively.
.claude-plans/
.claude-memory/

# Bench-build output that gets written into the source tree when bench
# uses a symlink to apps/frappe_ai (local dev only — the real build
# output lives under sites/assets/ in the bench).
frappe_ai/public/dist/

# Scratch space for local Claude/Playwright audits — screenshots, repro
# captures, anything generated by an in-session investigation that
# shouldn't pollute the repo.
tmp/

# Tool caches and IDE metadata — repo previously relied on per-developer
# global ignores for these; spelling them out here keeps a fresh clone on
# a teammate's box clean regardless of their global gitconfig.
.ruff_cache/
.idea/
.vscode/
.cursor/
.antigravity/

# Vitest coverage output (only generated when devs pass --coverage).
coverage/

# Editor / merge-tool detritus.
*.bak
*.orig
*~

# Local secrets — repo doesn't ship a root .env today; pre-empt the
# inevitable accidental check-in.
.env
.env.local
.mcp.json
